{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/stale-leads",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/send-outreach?limit=10",
      "schedule": "0 17 * * *"
    }
  ]
}
