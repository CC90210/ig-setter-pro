# Turso (SQLite edge database — free tier)
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Webhook security (shared with the Python Playwright daemon)
WEBHOOK_SECRET=random-string-matching-python-daemon
WEBHOOK_VERIFY_TOKEN=random-string-for-meta-verification

# Python Playwright daemon (set these in CMO-Agent/.env.agents too)
PULSE_WEBHOOK_URL=https://your-app.vercel.app/api/webhook
PULSE_ACCOUNT_ID=your-account-row-id
PULSE_IG_PAGE_ID=your-instagram-page-id
PULSE_IG_USERNAME=your-instagram-username

# Default account (multi-account tokens stored in accounts table)
IG_ACCESS_TOKEN=your-instagram-access-token
IG_PAGE_ID=your-page-id

# Facebook App (for token refresh)
FB_APP_ID=your-facebook-app-id
FB_APP_SECRET=your-facebook-app-secret

# Anthropic (required — powers Setter Doctrine classify + respond)
ANTHROPIC_API_KEY=sk-ant-...

# Auto-send (true = AI sends without human approval, false = draft only)
AUTO_SEND_ENABLED=false

# Vercel Cron auth — stale-lead scanner + proactive outreach dispatcher
# Generate: openssl rand -hex 32
CRON_SECRET=random-32-byte-hex
